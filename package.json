{
  "name": "agentic-bank",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "api:dev": "npm run dev --workspace=apps/api",
    "mobile:dev": "npm run dev --workspace=apps/mobile"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "react": "19.2.0"
  }
}
