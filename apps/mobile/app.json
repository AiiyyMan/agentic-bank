{
  "expo": {
    "name": "Agentic Bank",
    "slug": "agentic-bank",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "agentic-bank",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f23"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agenticbank.app"
    },
    "android": {
      "package": "com.agenticbank.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f23",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b68aa798-3a74-453d-8884-11f5d9c72a42"
      }
    },
    "owner": "tensare"
  }
}
