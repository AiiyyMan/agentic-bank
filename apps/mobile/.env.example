# Mobile app environment variables
# These get baked into the JS bundle at build time (EXPO_PUBLIC_ prefix required)

# ── API Server ────────────────────────────────────────────────
# URL of the running API server
# Local development: http://localhost:3000
# Android emulator: http://10.0.2.2:3000 (localhost doesn't work)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Supabase (Auth) ──────────────────────────────────────────
# Same project as the API, but use the ANON key (not service role)
# Find at: https://supabase.com → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJyour-anon-key-here

# ── Knock (Notifications) ──────────────────────────────────
# Public key: https://knock.app → Developers → API Keys
EXPO_PUBLIC_KNOCK_PUBLIC_API_KEY=pk_test_your-public-key
# Channel IDs: same as API server values
EXPO_PUBLIC_KNOCK_EXPO_CHANNEL_ID=your-expo-channel-uuid
EXPO_PUBLIC_KNOCK_FEED_CHANNEL_ID=your-feed-channel-uuid
