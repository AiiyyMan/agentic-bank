# ── Griffin BaaS (sandbox) ─────────────────────────────────────
# Sign up: https://app.griffin.com → Create sandbox organisation
# API key: Dashboard → API Keys → Create key
GRIFFIN_API_KEY=g-test-your-key-here
GRIFFIN_ORG_ID=og.your-org-id
GRIFFIN_BASE_URL=https://api.griffin.com

# Primary (master) account URL — used for balance normalisation
# Find at: Dashboard → Bank Accounts → click your master account → copy URL from browser
GRIFFIN_PRIMARY_ACCOUNT_URL=/v0/bank/accounts/ba.your-account-id

# Embedded product URL — used when opening customer bank accounts
# Find at: Dashboard → Products → click product → copy URL
GRIFFIN_EMBEDDED_PRODUCT_URL=/v0/organizations/og.your-org-id/bank/products/bp.your-product-id

# KYC workflow URL — used during customer onboarding
# Find at: Dashboard → Workflows → copy reliance verification workflow URL
GRIFFIN_RELIANCE_WORKFLOW_URL=/v0/workflows/wf.your-workflow-id

# ── Supabase (Database + Auth) ────────────────────────────────
# Sign up: https://supabase.com → New Project
# Find at: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJyour-service-role-key-here

# ── Anthropic (Claude AI Agent) ───────────────────────────────
# Sign up: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App Config ────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Banking Adapter ──────────────────────────────────────────
# true = use MockBankingAdapter (Supabase-only, no Griffin needed)
# false = use GriffinAdapter (requires Griffin sandbox credentials above)
USE_MOCK_BANKING=true
