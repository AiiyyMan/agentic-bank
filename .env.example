# ===== GRIFFIN (Banking API) =====
# Get from: https://app.griffin.com → API Keys
GRIFFIN_API_KEY=g-test-...
GRIFFIN_ORG_ID=og.your-org-id
GRIFFIN_BASE_URL=https://api.griffin.com
# Your organization's primary (master) account URL — used for balance normalization
GRIFFIN_PRIMARY_ACCOUNT_URL=/v0/bank/accounts/ba.xxxxx
# Embedded product URL for opening customer accounts
GRIFFIN_EMBEDDED_PRODUCT_URL=/v0/organizations/og.xxxxx/bank/products/bp.xxxxx
# KYC workflow URL for customer onboarding
GRIFFIN_RELIANCE_WORKFLOW_URL=/v0/workflows/wf.xxxxx

# ===== SUPABASE (Database + Auth) =====
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ===== ANTHROPIC (Claude AI Agent) =====
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ===== WISE (Stretch Goal — not yet implemented) =====
WISE_API_TOKEN=
WISE_BASE_URL=https://api.wise-sandbox.com

# ===== APP CONFIG =====
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ===== BANKING ADAPTER =====
# true = MockBankingAdapter (no Griffin needed), false = GriffinAdapter
USE_MOCK_BANKING=true
